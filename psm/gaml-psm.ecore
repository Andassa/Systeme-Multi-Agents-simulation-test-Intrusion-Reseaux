  <!-- ==================================================================
       ÉNUMÉRATIONS
       ================================================================== -->

  <eClassifiers xsi:type="ecore:EEnum" name="ArchitectureKind">
    <eAnnotations source="doc">
      <details key="restriction" value="GAMA 2025.6.4 en propose onze. Trois seulement sont retenues : celles sur lesquelles se projettent les trois classes d'agent du PIM. Les huit autres (simple_bdi, parallel_bdi, rules, sorted_tasks, probabilistic_tasks, user_first, user_last, user_only) sont volontairement hors périmètre — les inclure sans les employer produirait un métamodèle décoratif."/>
    </eAnnotations>
    <eLiterals name="REFLEX" value="0" literal="reflex"/>
    <eLiterals name="FSM" value="1" literal="fsm"/>
    <eLiterals name="WEIGHTED_TASKS" value="2" literal="weighted_tasks"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="SkillKind">
    <eLiterals name="FIPA" value="0" literal="fipa"/>
    <eLiterals name="MESSAGING" value="1" literal="messaging"/>
  </eClassifiers>

