    <eLiterals name="QUERIES" value="2" literal="queries"/>
    <eLiterals name="REQUESTS" value="3" literal="requests"/>
    <eLiterals name="REFUSES" value="4" literal="refuses"/>
    <eLiterals name="FAILURES" value="5" literal="failures"/>
    <eLiterals name="AGREES" value="6" literal="agrees"/>
    <eLiterals name="PROPOSES" value="7" literal="proposes"/>
