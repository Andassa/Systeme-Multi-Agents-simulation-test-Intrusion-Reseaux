  <eClassifiers xsi:type="ecore:EEnum" name="GenerationStrategy">
    <eAnnotations source="doc">
      <details key="adr" value="ADR-03 bis. TABLE : table de nœuds + parcours itératif, cible d'exécution. INLINE : cascade if/else lisible, cible de démonstration."/>
    </eAnnotations>
    <eLiterals name="TABLE" value="0" literal="table"/>
    <eLiterals name="INLINE" value="1" literal="inline"/>
  </eClassifiers>

