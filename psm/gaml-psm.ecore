    <eLiterals name="REPLY" value="1" literal="reply"/>
    <eLiterals name="END_CONVERSATION" value="2" literal="end_conversation"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ExperimentKind">
    <eLiterals name="GUI" value="0" literal="gui"/>
    <eLiterals name="BATCH" value="1" literal="batch"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ChartKind">
    <eLiterals name="SERIES" value="0" literal="series"/>
