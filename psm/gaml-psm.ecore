    <eLiterals name="FLOAT" value="1" literal="float"/>
    <eLiterals name="BOOL" value="2" literal="bool"/>
    <eLiterals name="STRING" value="3" literal="string"/>
    <eLiterals name="LIST" value="4" literal="list"/>
    <eLiterals name="MAP" value="5" literal="map"/>
    <eLiterals name="MATRIX" value="6" literal="matrix"/>
    <eLiterals name="AGENT" value="7" literal="agent"/>
    <eLiterals name="MESSAGE" value="8" literal="message"/>
    <eLiterals name="FILE" value="9" literal="file"/>
    <eLiterals name="PAIR" value="10" literal="pair"/>
